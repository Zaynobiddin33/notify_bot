# Copy this file to .env and fill in the values.
TELEGRAM_BOT_TOKEN=123456789:ABCDEF...your bot token...
BOT_ADMIN_ID=123456789
BOT_DB_PATH=users.db
BOT_CHECK_INTERVAL_SECONDS=300
BOT_NOTIFICATION_TEXT=Qabul Ochildi
BOT_USE_XVFB=true
BOT_XVFB_FORCE_HEADED=true
BOT_XVFB_SERVER_ARGS="-screen 0 1920x1080x24 -ac +extension RANDR"
PRENOTAMI_EMAIL=your-email@example.com
PRENOTAMI_PASSWORD=your-password
PRENOTAMI_HEADLESS=false
PRENOTAMI_LOCALE=it-IT
